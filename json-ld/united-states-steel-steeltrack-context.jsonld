      "@id": "uss:shipDate",
      "@type": "xsd:date"
    },
    "carrier": {
      "@id": "uss:carrier",
      "@type": "xsd:string"
    },
    "destination": {
      "@id": "uss:destination",
      "@type": "xsd:string"
    },
    "reports": {
