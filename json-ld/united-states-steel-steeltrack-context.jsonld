    "ShipmentList": "uss:ShipmentList",
    "Shipment": "uss:Shipment",
    "TestReportList": "uss:TestReportList",
    "TestReport": "uss:TestReport",
    "itemId": {
      "@id": "uss:itemId",
      "@type": "xsd:string"
    },
