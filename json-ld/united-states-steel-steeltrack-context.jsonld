      "@id": "uss:weightUnit",
      "@type": "xsd:string"
    },
    "location": {
      "@id": "uss:location",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "uss:status",
      "@type": "xsd:string"
    },
    "total": {
      "@id": "uss:total",
