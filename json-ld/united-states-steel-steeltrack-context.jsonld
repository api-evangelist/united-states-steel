      "@id": "uss:quantity",
      "@type": "xsd:decimal"
    },
    "quantityUnit": {
      "@id": "uss:quantityUnit",
      "@type": "xsd:string"
    },
    "orderDate": {
      "@id": "uss:orderDate",
      "@type": "xsd:date"
    },
    "requiredDate": {
      "@id": "uss:requiredDate",
      "@type": "xsd:date"
    },
    "estimatedDeliveryDate": {
      "@id": "uss:estimatedDeliveryDate",
      "@type": "xsd:date"
    },
    "shipments": {
